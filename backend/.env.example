# Copy to backend/.env and fill in real values. Never commit the .env file.

# --- Database -------------------------------------------------------------
# Local default already lives in database.py: postgresql+psycopg://wub@localhost:5432/tap_in
# Override here if you point at a different DB.
# DATABASE_URL=postgresql+psycopg://user:pass@host:5432/dbname

# --- App-issued session JWT ----------------------------------------------
# Sign/verify the token we hand back to the iOS app.
# Generate a strong value: `python -c "import secrets; print(secrets.token_urlsafe(64))"`
JWT_SECRET=replace-me-with-a-long-random-string

# --- Sign in with Apple --------------------------------------------------
# The iOS bundle ID. Apple sets the `aud` claim on identity tokens to this.
APPLE_AUDIENCE=com.jacobhancock.HypeMusic

# --- Dev-only auth bypass ------------------------------------------------
# Set to "1" locally so the iOS simulator can mint a session without Apple
# (used until you enroll in the Apple Developer Program). MUST be unset/0 in
# production — when enabled, `POST /auth/dev` will create real users.
DEV_AUTH_ENABLED=1

# --- Spotify OAuth (PKCE) -------------------------------------------------
# Create an app at https://developer.spotify.com/dashboard. Register the
# redirect URI exactly as the iOS app uses it: tap-in-login://callback
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
